# Auto-detect text files and normalize line endings

* text=auto

# Force LF for source code and data files

*.py text eol=lf
*.csv text eol=lf
*.txt text eol=lf
*.json text eol=lf

# Windows-specific scripts (if any)

*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files (no line ending changes)

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
